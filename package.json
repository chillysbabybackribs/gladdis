{
  "name": "gladdis",
  "version": "0.1.2",
  "description": "CDP-owned browser + chat desktop app (Cursor-dark themed)",
  "desktopName": "gladys",
  "main": "out/main/index.js",
  "author": "dp",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "pack": "npm run build && electron-builder --config electron-builder.config.cjs --dir",
    "dist": "npm run build && electron-builder --config electron-builder.config.cjs",
    "dist:mac": "npm run build && electron-builder --config electron-builder.config.cjs --mac",
    "dist:win": "npm run build && electron-builder --config electron-builder.config.cjs --win",
    "dist:linux": "npm run build && electron-builder --config electron-builder.config.cjs --linux",
    "release:doctor": "node scripts/release-doctor.cjs",
    "start": "electron-vite preview",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "check:size": "node scripts/check-file-size.cjs",
    "check": "npm run typecheck && npm test"
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.4.1",
    "electron-devtools-installer": "^4.0.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "@electron/notarize": "^3.1.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@google/genai": "^2.9.0",
    "@lydell/node-pty": "^1.2.0-beta.12",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "dompurify": "^3.4.7",
    "marked": "^18.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^3.25.76"
  }
}
